# ============================================================
# NGR Credential Template — env.template
# ============================================================
# Copy this file to .env (in repo root) and fill in values.
# .env is gitignored — NEVER commit it.
#
# Load with: source .env  (Mac/Linux)
#            Get-Content .env | ForEach-Object { $env:... }  (Windows)
# ============================================================

# ── AWS ─────────────────────────────────────────────────────
# Option A: Access keys (use only if no IAM role available)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=          # Only for temporary credentials
AWS_DEFAULT_REGION=us-east-1

# Option B: On EC2 — attach an IAM Role to the instance instead.
#           boto3 will pick it up automatically. No keys needed.

# ── Snowflake ────────────────────────────────────────────────
NGR_SNOWFLAKE_ACCOUNT=      # e.g. xy12345.us-east-1
NGR_SNOWFLAKE_USER=
NGR_SNOWFLAKE_PASSWORD=
NGR_SNOWFLAKE_WAREHOUSE=    # e.g. COMPUTE_WH
NGR_SNOWFLAKE_DATABASE=
NGR_SNOWFLAKE_SCHEMA=
NGR_SNOWFLAKE_ROLE=         # e.g. SYSADMIN

# ── KQL / Azure Data Explorer ────────────────────────────────
NGR_KQL_CLUSTER=            # e.g. https://mycluster.eastus.kusto.windows.net
NGR_KQL_DATABASE=
NGR_KQL_TENANT_ID=          # Azure AD Tenant ID
NGR_KQL_CLIENT_ID=          # App Registration Client ID
NGR_KQL_CLIENT_SECRET=      # App Registration Client Secret

# ── Informatica IICS ─────────────────────────────────────────
NGR_INFORMATICA_BASE_URL=   # e.g. https://dm-us.informaticacloud.com
NGR_INFORMATICA_USERNAME=
NGR_INFORMATICA_PASSWORD=
NGR_INFORMATICA_ORG_ID=

# ── Talend Cloud (TMC) ───────────────────────────────────────
NGR_TALEND_TMC_URL=         # e.g. https://api.us.cloud.talend.com
NGR_TALEND_API_KEY=
NGR_TALEND_WORKSPACE_ID=

# ── dbt ──────────────────────────────────────────────────────
NGR_DBT_PROFILES_DIR=       # Path to profiles.yml directory
NGR_DBT_TARGET=prod         # dbt target (dev/prod)

# ── Anthropic / Claude ───────────────────────────────────────
ANTHROPIC_API_KEY=          # sk-ant-...
