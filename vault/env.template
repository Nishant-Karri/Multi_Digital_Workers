# ============================================================
# NGR Credential Template — env.template
# ============================================================
# Copy this file to .env (in repo root) and fill in values.
# .env is gitignored — NEVER commit it.
#
# Load with: source .env  (Mac/Linux)
#            Get-Content .env | ForEach-Object { $env:... }  (Windows)
# ============================================================

# ── AWS ─────────────────────────────────────────────────────
# Option A: Access keys (use only if no IAM role available)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=          # Only for temporary credentials
AWS_DEFAULT_REGION=us-east-1

# Option B: On EC2 — attach an IAM Role to the instance instead.
#           boto3 will pick it up automatically. No keys needed.

# ── Snowflake ────────────────────────────────────────────────
NGR_SNOWFLAKE_ACCOUNT=      # e.g. xy12345.us-east-1
NGR_SNOWFLAKE_USER=
NGR_SNOWFLAKE_PASSWORD=
NGR_SNOWFLAKE_WAREHOUSE=    # e.g. COMPUTE_WH
NGR_SNOWFLAKE_DATABASE=
NGR_SNOWFLAKE_SCHEMA=
NGR_SNOWFLAKE_ROLE=         # e.g. SYSADMIN

# ── KQL / Azure Data Explorer ────────────────────────────────
NGR_KQL_CLUSTER=            # e.g. https://mycluster.eastus.kusto.windows.net
NGR_KQL_DATABASE=
NGR_KQL_TENANT_ID=          # Azure AD Tenant ID
NGR_KQL_CLIENT_ID=          # App Registration Client ID
NGR_KQL_CLIENT_SECRET=      # App Registration Client Secret

# ── Informatica IICS ─────────────────────────────────────────
NGR_INFORMATICA_BASE_URL=   # e.g. https://dm-us.informaticacloud.com
NGR_INFORMATICA_USERNAME=
NGR_INFORMATICA_PASSWORD=
NGR_INFORMATICA_ORG_ID=

# ── Talend Cloud (TMC) ───────────────────────────────────────
NGR_TALEND_TMC_URL=         # e.g. https://api.us.cloud.talend.com
NGR_TALEND_API_KEY=
NGR_TALEND_WORKSPACE_ID=

# ── dbt ──────────────────────────────────────────────────────
NGR_DBT_PROFILES_DIR=       # Path to profiles.yml directory
NGR_DBT_TARGET=prod         # dbt target (dev/prod)

# ── Kafka / Confluent ────────────────────────────────────────
NGR_KAFKA_BOOTSTRAP_SERVERS=   # e.g. broker1:9092,broker2:9092
NGR_KAFKA_SASL_MECHANISM=      # PLAIN or SCRAM-SHA-256 (leave blank if no auth)
NGR_KAFKA_SECURITY_PROTOCOL=   # SASL_SSL or PLAINTEXT
NGR_KAFKA_SASL_USERNAME=
NGR_KAFKA_SASL_PASSWORD=
NGR_KAFKA_GROUP_ID=ngr-consumer

# ── Databricks ───────────────────────────────────────────────
NGR_DATABRICKS_HOST=           # e.g. https://adb-1234567890.1.azuredatabricks.net
NGR_DATABRICKS_HTTP_PATH=      # e.g. /sql/1.0/warehouses/abc123
NGR_DATABRICKS_TOKEN=          # Personal Access Token

# ── MLflow ───────────────────────────────────────────────────
NGR_MLFLOW_TRACKING_URI=       # e.g. https://mlflow.company.com or databricks
NGR_MLFLOW_USERNAME=
NGR_MLFLOW_PASSWORD=

# ── Airflow ──────────────────────────────────────────────────
NGR_AIRFLOW_BASE_URL=          # e.g. https://airflow.company.com
NGR_AIRFLOW_USER=
NGR_AIRFLOW_PASSWORD=

# ── DataHub ──────────────────────────────────────────────────
NGR_DATAHUB_SERVER=            # e.g. http://datahub-gms:8080
NGR_DATAHUB_TOKEN=

# ── Collibra ─────────────────────────────────────────────────
NGR_COLLIBRA_BASE_URL=         # e.g. https://company.collibra.com
NGR_COLLIBRA_USER=
NGR_COLLIBRA_PASSWORD=

# ── Feast (local repo path) ───────────────────────────────────
NGR_FEAST_REPO_PATH=./feature_repo

# ── Azure ML ─────────────────────────────────────────────────
NGR_AZURE_ML_SUBSCRIPTION_ID=
NGR_AZURE_ML_RESOURCE_GROUP=
NGR_AZURE_ML_WORKSPACE_NAME=
NGR_AZURE_ML_TENANT_ID=
NGR_AZURE_ML_CLIENT_ID=
NGR_AZURE_ML_CLIENT_SECRET=

# ── GCP / BigQuery / Vertex AI ───────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS= # Path to service-account JSON file
NGR_GCP_PROJECT=

# ── Anthropic / Claude ───────────────────────────────────────
ANTHROPIC_API_KEY=          # sk-ant-...
