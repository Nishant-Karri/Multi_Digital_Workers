{
  "pool": {
    "min_workers": 1,
    "max_workers": 10,
    "scale_up_threshold": 3,
    "scale_down_idle_minutes": 10,
    "max_parallel_large_tasks": 3,
    "max_parallel_epics": 2
  },
  "task_sizes": {
    "small":  { "max_subtasks": 1,  "max_workers": 1,  "timeout_minutes": 10,  "description": "Single focused task, no decomposition" },
    "medium": { "max_subtasks": 1,  "max_workers": 1,  "timeout_minutes": 30,  "description": "Single agent, moderate complexity" },
    "large":  { "max_subtasks": 5,  "max_workers": 3,  "timeout_minutes": 120, "description": "Decomposed into subtasks, multiple workers" },
    "epic":   { "max_subtasks": 20, "max_workers": 10, "timeout_minutes": 480, "description": "Multi-stage pipeline, full agent fleet" }
  },
  "auto_classify": {
    "keywords_large": ["refactor", "migrate", "pipeline", "all tables", "entire", "end-to-end", "full"],
    "keywords_epic":  ["etl", "data warehouse", "multi-step", "phases", "sprint", "overhaul"]
  },
  "worker_roles": {
    "data_engineer":        { "handles": ["batch_ingestion","streaming_ingestion","api_ingestion","database_replication","spark_transformation","sql_transformation","data_wrangling","data_migration","reverse_etl"], "description": "Ingestion, transformation, migration" },
    "analytics_engineer":   { "handles": ["dbt_modeling","sql_transformation"],                                                       "description": "dbt models, semantic layer, SQL" },
    "streaming_engineer":   { "handles": ["streaming_ingestion"],                                                                      "description": "Kafka, Kinesis, Flink, real-time" },
    "data_scientist":       { "handles": ["feature_engineering","model_training","mlops"],                                             "description": "ML, features, MLOps" },
    "analytics":            { "handles": ["bi_report","kql_analytics","ad_hoc_analysis"],                                              "description": "Dashboards, KQL, EDA" },
    "governance":           { "handles": ["data_lineage","data_catalog","data_privacy","access_control","data_sharing"],               "description": "Lineage, catalog, PII, RBAC" },
    "dataops":              { "handles": ["pipeline_orchestration","cicd_data"],                                                       "description": "Airflow, Prefect, CI/CD" },
    "cloud_infra":          { "handles": ["cloud_data_infra","cost_optimization"],                                                     "description": "AWS/Azure/GCP infra, cost" },
    "data_quality":         { "handles": ["data_quality","data_profiling","anomaly_detection"],                                        "description": "GE, dbt tests, anomaly detection" },
    "general":              { "handles": ["*"],                                                                                        "description": "Catch-all for unclassified tasks" }
  }
}
